# ── Git Secure-AI backend configuration ──
# Copy to `.env` and fill in. Never commit the real .env or the private key.

# Where this backend is reachable (used to build the OAuth redirect_uri).
PUBLIC_URL=http://localhost:8787
PORT=8787

# The frontend origin — used for CORS, the post-login redirect, and cookie scope.
FRONTEND_URL=http://localhost:5173

# Database. SQLite for local dev; switch provider to postgresql for production.
DATABASE_URL="file:./dev.db"

# Random string used to sign the session cookie. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# ── GitHub App credentials ──
# Create the app at: https://github.com/settings/apps/new  (see README.md)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Provide the private key as EITHER a path to the downloaded .pem ...
GITHUB_APP_PRIVATE_KEY_PATH=./secure-ai.private-key.pem
# ... OR inline (escape newlines as \n). PATH takes precedence if both are set.
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret — not used yet (scan-on-push lands in a later roadmap step).
# GITHUB_WEBHOOK_SECRET=

# Scanner binaries — default to ./bin/gitleaks(.exe) and ./bin/osv-scanner(.exe).
# Override only if you keep them elsewhere or installed them on PATH.
# GITLEAKS_PATH=./bin/gitleaks.exe
# OSV_SCANNER_PATH=./bin/osv-scanner.exe

# Run the repo's test suite during fix validation (installs deps + runs tests).
# Off by default — it executes untrusted project code, so sandbox it in prod.
# ENABLE_TEST_VALIDATION=true

# Isolation for untrusted execution (npm install/test).
#   none   = run on host with a secret-stripped environment (default)
#   docker = run in an ephemeral, resource-limited container (needs Docker running)
# SANDBOX_MODE=docker
# SANDBOX_IMAGE=node:20-alpine
